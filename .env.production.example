# Copy this file to /etc/ai-customer-service/production.env on the server.
# Never commit the real file. Keep values single-line and do not add shell commands.

COMPOSE_PROJECT_NAME=ai-customer-service
APP_IMAGE=ghcr.io/example/ai-customer-service:1.0.0
APP_PORT=8000

POSTGRES_IMAGE=pgvector/pgvector:pg17
POSTGRES_DB=ai_customer_service
POSTGRES_USER=ai_customer_service
# Generate URL-safe values with: openssl rand -hex 32
POSTGRES_PASSWORD=replace_with_64_hex_characters

REDIS_IMAGE=redis:7-alpine
REDIS_PASSWORD=replace_with_64_hex_characters

MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z
MINIO_ROOT_USER=ai_customer_service_root
MINIO_ROOT_PASSWORD=replace_with_64_hex_characters
APP_S3_ACCESS_KEY=ai_customer_service_app
APP_S3_SECRET_KEY=replace_with_64_hex_characters
APP_S3_BUCKET=ai-customer-service
APP_S3_REGION=us-east-1

APP_ENV=production
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_JWT_SECRET=replace_with_at_least_64_random_characters
APP_CREDENTIAL_PEPPER=replace_with_another_64_random_characters
# Generate with: uv run python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
APP_ENCRYPTION_KEY=replace_with_a_fernet_key
APP_ADMIN_ACCESS_TOKEN_MINUTES=60
APP_CUSTOMER_TOKEN_MINUTES=15
APP_CORS_ORIGINS=["https://support.example.com"]
APP_ALLOW_PRIVATE_PROVIDER_URLS=false
