APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_customer_service
APP_REDIS_URL=redis://localhost:6379/0
APP_S3_ENDPOINT_URL=http://localhost:9000
APP_S3_ACCESS_KEY=minioadmin
APP_S3_SECRET_KEY=minioadmin
APP_S3_BUCKET=ai-customer-service
APP_S3_REGION=us-east-1
APP_JWT_SECRET=replace-with-at-least-32-random-characters
APP_CREDENTIAL_PEPPER=replace-with-another-long-random-secret
APP_ENCRYPTION_KEY=replace-with-a-fernet-key
APP_ADMIN_ACCESS_TOKEN_MINUTES=60
APP_CUSTOMER_TOKEN_MINUTES=15
APP_CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]
APP_ALLOW_PRIVATE_PROVIDER_URLS=false
